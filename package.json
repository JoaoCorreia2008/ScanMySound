{
  "name": "scanmysound",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n BACKEND,FRONTEND -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "lint:frontend": "npm run lint --workspace frontend",
    "test:backend": "npm run test --workspace backend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:push": "npm run prisma:push --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "models:download": "npm run models:download --workspace frontend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
